{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://review-and-rating-app.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://review-and-rating-app.onrender.com/uploads/:path*"
    },
    { "source": "/((?!api|uploads).*)", "destination": "/index.html" }
  ]
}
